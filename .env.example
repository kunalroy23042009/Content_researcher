# ============================================================
# Creator Content Radar — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# REQUIRED keys (app will fail without these):
# ============================================================

# YouTube Data API v3 key — get from https://console.cloud.google.com
YOUTUBE_API_KEY=

# At least ONE of these AI providers is required:
GEMINI_API_KEY=       # Google Gemini — https://aistudio.google.com/app/apikey
GROQ_API_KEY=         # Groq (free, fast) — https://console.groq.com/keys
OPENROUTER_API_KEY=   # OpenRouter (paid) — https://openrouter.ai/keys

# Which AI to use first: auto, gemini, groq, openrouter
AI_PROVIDER=auto

# ============================================================
# OPTIONAL — leave blank to skip these features
# ============================================================

# Reddit API — for Reddit content search
# Register at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=creator-content-radar/0.1

# JWT auth secret — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-change-in-production

# Database — SQLite for local, PostgreSQL for production
DATABASE_URL=sqlite:///./data/cache.db

# Stripe billing — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_BUSINESS_MONTHLY=

# Your deployed app URL (used for Stripe redirect URLs)
APP_URL=http://localhost:8000
